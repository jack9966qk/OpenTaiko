default_platform(:ios)

BETA_GROUPS = ["beta"].freeze
APP_IDENTIFIER = "com.opentaiko.mobile".freeze

def asc_api_key
  api_key_content = ENV["APP_STORE_CONNECT_API_KEY_KEY"]
  is_base64 = !api_key_content.include?("-----BEGIN")
  app_store_connect_api_key(
    key_id: ENV["APP_STORE_CONNECT_API_KEY_KEY_ID"],
    issuer_id: ENV["APP_STORE_CONNECT_API_KEY_ISSUER_ID"],
    key_content: api_key_content,
    is_key_content_base64: is_base64
  )
end

platform :ios do
  desc "Resigns an unsigned IPA"
  lane :resign_ipa do |options|
    ipa_path = options[:ipa_path]

    unless ipa_path && File.exist?(ipa_path)
      UI.user_error!("Could not find IPA at path: #{ipa_path}")
    end

    resign(
      ipa: ipa_path,
      signing_identity: ENV["SIGNING_IDENTITY"],
      provisioning_profile: ENV["PROVISIONING_PROFILE_PATH"]
    )
  end

  desc "Uploads a signed IPA to TestFlight and distributes it to the beta group (fallback if altool fails)"
  lane :upload_ipa do |options|
    ipa_path = options[:ipa_path]

    unless ipa_path && File.exist?(ipa_path)
      UI.user_error!("Could not find IPA at path: #{ipa_path}")
    end

    upload_to_testflight(
      ipa: ipa_path,
      api_key: asc_api_key,
      groups: BETA_GROUPS,
      skip_waiting_for_build_processing: false
    )
  end

  desc "Distributes the latest processed build on App Store Connect to the beta group"
  lane :distribute_to_testers do
    upload_to_testflight(
      api_key: asc_api_key,
      app_identifier: APP_IDENTIFIER,
      distribute_only: true,
      groups: BETA_GROUPS,
      skip_waiting_for_build_processing: false
    )
  end
end
